# Copy this file to values.secret.yaml and fill in all values.
# values.secret.yaml is gitignored — never commit it.
secrets:
  postgresPassword: "CHANGE_ME"
  djangoSecretKey: "CHANGE_ME"
  djangoSecretKeyFallbacks: ""
  mailgunApiKey: ""
  sentryUrl: ""
  openTelemetryUrl: ""
  pwaSha256Fingerprints: ""
  cloudflare:
    # Paste PEM content of cloudflare.pem here
    cert: |
      -----BEGIN CERTIFICATE-----
      CHANGE_ME
      -----END CERTIFICATE-----
    # Paste PEM content of cloudflare.key here
    key: |
      -----BEGIN EC PRIVATE KEY-----
      CHANGE_ME
      -----END EC PRIVATE KEY-----
