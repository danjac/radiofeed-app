# Copy to values.secret.yaml and fill in real values.
# values.secret.yaml is gitignored — never commit it.

kube-prometheus-stack:
  grafana:
    # Grafana admin password
    adminPassword: "CHANGE_ME"

    # Optional SMTP for alert emails
    # smtp:
    #   enabled: true
    #   host: smtp.example.com
    #   user: alerts@example.com
    #   password: CHANGE_ME
    #   from_address: alerts@example.com
    #   from_name: Grafana

    ingress:
      # Grafana subdomain — e.g. grafana.example.com
      hosts:
        - grafana.example.com
